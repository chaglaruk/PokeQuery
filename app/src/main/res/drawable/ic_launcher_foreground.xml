<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.5.2 (Fix 1): refreshed adaptive-icon foreground.

  Original brand concept — a premium "query shield": a rounded navy shield containing a
  collection grid (4 dots) overlaid by an electric-cyan magnifier, with two cyan/gold spark
  accents. Deep navy / electric cyan only — matches the Stitch UI direction.

  Safe zone: adaptive icons crop the outer ~33% on a 108dp viewport. All meaningful artwork
  is kept within the central ~72dp circle (cx=cy=54, r<=36) so it survives any mask shape.

  No Poke Ball, no creature, no official logo, no copyrighted shape, color, or layout.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft inner vignette ring to lift the shield off the background. -->
    <path android:fillColor="#1400E5FF" android:pathData="M54,54m-37,0a37,37 0,1 1,74 0a37,37 0,1 1,-74 0" />

    <!-- Shield body: navy face with a faint cyan outline. -->
    <path
        android:fillColor="#0B2545"
        android:strokeColor="#6600E5FF"
        android:strokeWidth="2.2"
        android:strokeLineJoin="round"
        android:pathData="M54,23 L34,31 L34,50 C34,67 54,80 54,80 C54,80 74,67 74,50 L74,31 Z" />
    <!-- Shield inner highlight edge. -->
    <path
        android:fillColor="#0F3D6B"
        android:pathData="M54,28 L39,34 L39,50 C39,63 51,73 54,76 C57,73 69,63 69,50 L69,34 Z" />

    <!-- Collection grid: 4 cyan dots = a queried collection. -->
    <path android:fillColor="#00E5FF" android:pathData="M45,46m-2.6,0a2.6,2.6 0,1 1,5.2 0a2.6,2.6 0,1 1,-5.2 0" />
    <path android:fillColor="#00E5FF" android:pathData="M63,46m-2.6,0a2.6,2.6 0,1 1,5.2 0a2.6,2.6 0,1 1,-5.2 0" />
    <path android:fillColor="#00E5FF" android:pathData="M45,60m-2.6,0a2.6,2.6 0,1 1,5.2 0a2.6,2.6 0,1 1,-5.2 0" />
    <path android:fillColor="#00E5FF" android:pathData="M63,60m-2.6,0a2.6,2.6 0,1 1,5.2 0a2.6,2.6 0,1 1,-5.2 0" />

    <!-- Magnifier: cyan ring + handle scanning the grid = the "query". -->
    <path
        android:strokeColor="#1DE9FF"
        android:strokeWidth="3.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,53m-12,0a12,12 0,1 1,24 0a12,12 0,1 1,-24 0" />
    <path
        android:strokeColor="#1DE9FF"
        android:strokeWidth="4.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M63,62 L72,71" />

    <!-- Spark accents (gold + cyan): the brand "smart" cue. Kept inside the safe zone. -->
    <path android:fillColor="#FFC928" android:pathData="M70,32 L71.6,36.6 L76.2,38.2 L71.6,39.8 L70,44.4 L68.4,39.8 L63.8,38.2 L68.4,36.6 Z" />
    <path android:fillColor="#00E5FF" android:pathData="M38,32 L39.1,35.2 L42.3,36.3 L39.1,37.4 L38,40.6 L36.9,37.4 L33.7,36.3 L36.9,35.2 Z" />
</vector>
