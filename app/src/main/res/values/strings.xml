    <!-- Risk explanations -->
    <string name="risk_info_title">Inspection only</string>
    <string name="risk_info_short">This is an inspection query. It shows matches but does not suggest a destructive action.</string>
    <string name="risk_info_detailed">Inspection queries are safe to run: they only display Pokémon. Still review the matches so you understand what is in your storage.</string>
    <string name="risk_info_check1">Open the search and read the matches.</string>
    <string name="risk_info_check2">No transfer or trade is suggested.</string>
    <string name="risk_info_check3">Use it to learn what you own.</string>

    <string name="risk_low_title">Low risk — review matches</string>
    <string name="risk_low_short">A narrow query. Still review the matches before acting.</string>
    <string name="risk_low_detailed">Low-risk strings are deliberately narrow, but a valuable Pokémon can still appear. Skim the results before transferring or trading.</string>
    <string name="risk_low_check1">Scroll through every match.</string>
    <string name="risk_low_check2">Keep anything you are unsure about.</string>
    <string name="risk_low_check3">Tag valuable Pokémon to protect them.</string>

    <string name="risk_medium_title">Medium risk — act carefully</string>
    <string name="risk_medium_short">This query is action-adjacent. Review carefully before transferring or trading.</string>
    <string name="risk_medium_detailed">Medium-risk strings are designed for cleanup or trading decisions. Valuable Pokémon may appear in the matches. Do not act on them blindly.</string>
    <string name="risk_medium_check1">Inspect every match before acting.</string>
    <string name="risk_medium_check2">Never transfer shiny, legendary, or favorite Pokémon by accident.</string>
    <string name="risk_medium_check3">When in doubt, keep the Pokémon.</string>

    <string name="risk_high_title">High risk — inspect first</string>
    <string name="risk_high_short">A broad or high-value query. Inspect every match before acting.</string>
    <string name="risk_high_detailed">High-risk strings can surface very valuable Pokémon. Treat every match as worth checking before any transfer or trade.</string>
    <string name="risk_high_check1">Inspect every single match.</string>
    <string name="risk_high_check2">Do not bulk-transfer the results.</string>
    <string name="risk_high_check3">Protect valuable Pokémon with tags or favorites.</string>

