    <!-- Goal explanations -->
    <string name="goal_exp_safe_cleanup">This is a REVIEW string targeting low-value candidates. It is not an automatic transfer command.</string>
    <string name="goal_exp_candy_prep">Finds extras. Count is based on Pokédex species number and may not distinguish shiny/form/costume differences.</string>
    <string name="goal_exp_trade_fodder">Finds candidates for trading. Real trade eligibility depends on friendship level and cannot be guaranteed by search strings.</string>
    <string name="goal_exp_hundo_check">Finds all perfect IV / hundo Pokémon. 4★ means 15/15/15.</string>
    <string name="goal_exp_untagged_cleanup">Finds Pokémon without any tags.</string>
    <string name="goal_exp_nundo_finder">Finds exact 0/0/0 IV Pokémon (Nundos).</string>
    <string name="goal_exp_pvp_candidates">Candidate search only. Final PvP rank depends on species, level, and IV spread.</string>
    <string name="goal_exp_lucky_trade">Finds older or distance-relevant Pokémon to review for trades. Review manually. Valuable Pokémon may appear. Trade eligibility and Lucky chance are not guaranteed by search strings.</string>
    <string name="goal_exp_expert">Custom search string. Review all matches in the game before acting.</string>

