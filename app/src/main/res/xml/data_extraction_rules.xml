<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for API 31+ (Android 12+).
   allowBackup="false" already disables cloud backup at the application level;
   these rules provide defense-in-depth by explicitly excluding DataStore
   preference files and any cache from both cloud backup and device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>