<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.6.1 — Android App Shortcuts (static).

  Static launcher long-press shortcuts that open the app directly to a high-value screen.
  No new permission, no network, no background work. They carry only a start_route extra that
  MainActivity forwards to MainNavigation.startDestination(). Back returns to Home.

  Icons use original vector drawables only (no Pokémon/Niantic/Nintendo assets).
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="safe_cleanup"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_safe_cleanup"
        android:shortcutShortLabel="@string/shortcut_safe_cleanup_short"
        android:shortcutLongLabel="@string/shortcut_safe_cleanup_long"
        android:shortcutDisabledMessage="@string/shortcut_safe_cleanup_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.caglar.pokequery"
            android:targetClass="com.caglar.pokequery.MainActivity">
            <extra android:name="start_route" android:value="detail_safe_cleanup" />
        </intent>
    </shortcut>

