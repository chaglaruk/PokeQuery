    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "These protection tokens are intentionally conservative in localized search strings.",
    "verificationStatus": "BETA",
    "safetyLevel": "review",
    "languageSensitive": true,
    "example": "!background&!locationbackground&!specialbackground&!ultrabeast",
    "commonMistake": "Assuming English fallback means the protection was forgotten."
  },
  {
    "id": "misconception_inspection_vs_action",
    "title": "Inspection-only vs action-adjacent risk",
    "syntax": "risk",
    "category": "Common Misconceptions",
    "tier": "T1",
    "description_tr": "",
    "description_en": "Hundo, Nundo, and PvP candidate searches can be Info because they are for inspection only. Cleanup, trade, candy prep, and expert workflows are action-adjacent because users may copy them before transfer, trade, or cleanup decisions, so RiskWarning is required.",
    "riskLevel": "Medium",
    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "Risk is based on likely user action, not just the text matched by the query.",
    "verificationStatus": "VERIFIED",
    "safetyLevel": "review",
    "languageSensitive": false,
    "example": "4*",
    "commonMistake": "Thinking every query with no exclusions is unsafe, or every protected query is safe to act on blindly."
