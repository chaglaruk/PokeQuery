  {
    "id": "misconception_pipe_operator",
    "title": "`|` is not a safe OR operator",
    "syntax": "|",
    "category": "Common Misconceptions",
    "tier": "T1",
    "description_tr": "",
    "description_en": "PokeQuery does not treat `|` as a safe OR operator and generated strings must not use it. Misusing `|` can produce unexpected results or fail depending on the game parser. Use the supported comma separator for OR-style groups when a generated or expert query needs OR behavior.",
    "riskLevel": "Medium",
    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "Expert Builder warns about `|`; generated strings replace it with comma.",
    "verificationStatus": "VERIFIED",
    "safetyLevel": "risky",
    "languageSensitive": true,
    "example": "shiny,legendary",
    "commonMistake": "Typing shiny|legendary and assuming it is a safe OR group."
  },
  {
    "id": "misconception_or_separator",
    "title": "OR separator rules",
    "syntax": ",",
    "category": "Common Misconceptions",
    "tier": "T1",
    "description_tr": "",
    "description_en": "PokeQuery's supported OR separator is the comma. Comma groups are evaluated inside the search string; Pok\u00e9mon GO does not support parentheses, so complex AND/OR expressions should be kept simple and reviewed in-game.",
    "riskLevel": "Low",
    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "Parentheses are not supported by PokeQuery generated strings.",
    "verificationStatus": "VERIFIED",
    "safetyLevel": "review",
    "languageSensitive": true,
    "example": "1*,2*&!shiny",
    "commonMistake": "Assuming `|` or parentheses work like a programming language."
  },
  {
    "id": "misconception_count_caveats",
    "title": "`count[N]` cleanup caveats",
    "syntax": "count2-",
    "category": "Common Misconceptions",
    "tier": "T2",
    "description_tr": "",
    "description_en": "`count2-` finds Pok\u00e9mon where you have two or more from the same Pok\u00e9dex species number. It may not distinguish shiny, form, costume, background, or other valuable variants, so cleanup/count outputs require strong explicit exclusions. Turkish `count` stays English until parser behavior is verified.",
    "riskLevel": "High",
    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "Count-based cleanup must exclude shiny, lucky, legendary, mythical, shadow, purified, favorite, traded, costume, Ultra Beast, and background variants.",
    "verificationStatus": "BETA",
    "safetyLevel": "risky",
    "languageSensitive": true,
    "example": "count2-&!shiny&!costume&!traded",
    "commonMistake": "Treating count2- as a safe duplicate-transfer list without exclusions."
  },
  {
    "id": "misconception_turkish_beta",
    "title": "Turkish search language is beta",
    "syntax": "Turkish",
    "category": "Common Misconceptions",
    "tier": "T2",
    "description_tr": "",
    "description_en": "Search String Language: Turkish is beta. Parser-sensitive tokens may intentionally remain English because a wrong localized token can silently return no results. This safety fallback is intentional, not a translation bug.",
    "riskLevel": "Medium",
    "sourceUrl": "local://pokequery/common-misconceptions",
    "lastVerified": "2026-06-25",
    "knownQuirks": "App Language and Search String Language are independent.",
    "verificationStatus": "BETA",
    "safetyLevel": "review",
    "languageSensitive": true,
    "example": "count2-&!shiny",
    "commonMistake": "Assuming every token should be translated when Turkish output is selected."
  },
  {
    "id": "misconception_background_ultrabeast",
    "title": "Background and Ultra Beast safety fallback",
    "syntax": "background",
    "category": "Common Misconceptions",
    "tier": "T2",
    "description_tr": "",
    "description_en": "`background`, `locationbackground`, `specialbackground`, and `ultrabeast` may remain English in generated strings for safety. PokeQuery avoids inventing localized parser-sensitive tokens until behavior is verified.",
