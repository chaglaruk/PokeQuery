    "id": "counter_count",
    "syntax": "count[N]",
    "category": "Counter",
    "tier": "T2",
    "description_tr": "Tür kopya sayısı",
    "description_en": "Counts occurrences by Pokédex species number. Useful for finding duplicates to transfer. 'count2-' finds any species where you own 2 or more. It does not distinguish between shinies, forms, or costumes.",
    "riskLevel": "High",
    "sourceUrl": "https://pokemongohub.net/",
    "lastVerified": "2026-06-20",
    "knownQuirks": "Does not distinguish shiny, form, gender, or costume. Bare count expands to count2-.",
    "verificationStatus": "beta",
    "safetyLevel": "risky",
    "languageSensitive": true,
    "example": "count2-&!shiny",
    "commonMistake": "The Turkish equivalent is contested (toplam/sayı/sayısı) and unverified. PokeQuery emits the English 'count' even in Turkish output until one candidate is confirmed live. See SearchTokenRegistry.COUNT_CANDIDATES."
  },
